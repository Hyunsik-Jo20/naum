{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:svc/:endpoint", "destination": "/api/proxy?svc=:svc&endpoint=:endpoint" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
