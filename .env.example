# 기상청 동네예보 + 에어코리아 사용 시 설정 (복사 → .env.local 로 저장)
#
# 1) 날씨 소스를 기상청으로 전환 (미설정/open-meteo 이면 Open-Meteo 사용)
VITE_WEATHER_SOURCE=kma
#
# 2) 공공데이터포털(data.go.kr) 인증키 — "Encoding" 인증키를 그대로 붙여넣기
#    (브라우저에 노출되지 않도록 VITE_ 접두사 없이 둡니다. vite.config 프록시에서만 사용)
DATAGOKR_KEY=여기에_인코딩_인증키_붙여넣기

# 카카오맵(교육청 지도) — Kakao Developers의 JavaScript 키
# 앱 설정 > 플랫폼 > Web 에 http://localhost:5173 등록 필요
VITE_KAKAO_JS_KEY=여기에_카카오_JavaScript_키_붙여넣기

# ── Supabase (클라우드 배포용) ──────────────────────────────
# 아래 두 값을 채우면 "클라우드 모드"로 동작(비식별 데이터만 Supabase에 저장).
# 비워두면 기존 로컬/in-browser 데모 그대로 — 연수 자료용은 이 상태로 사용.
# 값은 Supabase 대시보드 > Project Settings > API 에서 확인.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
